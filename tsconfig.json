{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "index.ts",
    "plugins/**/*.ts",
    "types/**/*.ts",
    "analysis/**/*.ts",
    "panel/**/*.tsx",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
